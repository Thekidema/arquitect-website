# ARQUITECT Website - Configuración de Entorno
# Copia este archivo a .env y personaliza los valores

# WhatsApp Integration
WHATSAPP_PHONE_NUMBER=50671668641
WHATSAPP_COUNTRY_CODE=+506
WHATSAPP_MESSAGE_DEFAULT=Hola, me gustaría solicitar una cotización

# Analytics (opcional)
